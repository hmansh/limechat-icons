{
  "name": "limechat-icons",
  "version": "1.0.0",
  "description": "Official icon library for Limechat",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build": "npm run generate && tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["icons", "limechat", "svg"],
  "license": "MIT"
}
